{
  "name": "webapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 3000",
    "build": "echo 'No build step needed - wrangler bundles directly'",
    "db:migrate:local": "wrangler d1 migrations apply webapp-db --local",
    "db:console:local": "wrangler d1 execute webapp-db --local",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.78.0"
  }
}
